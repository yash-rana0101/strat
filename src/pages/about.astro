---
/**
 * About Page — Company story, philosophy, research domains, values.
 */
import PageLayout from '@/layouts/PageLayout.astro';
import Container from '@/components/ui/Container.astro';
import Badge from '@/components/ui/Badge.astro';
import Button from '@/components/ui/Button.astro';
import Icon from '@/components/ui/Icon.astro';
---
<PageLayout title="About Strat Ai" description="A research-first AI company building intelligent products for modern financial markets." badge="Company" badgeVariant="emerald" breadcrumbs={[{ label: 'About' }]}>
  <!-- Vision & Mission -->
  <section class="py-16 md:py-20 bg-canvas transition-colors duration-300">
    <Container size="wide" class="!px-0">
      <div class="grid grid-cols-1 lg:grid-cols-2 border-y border-hairline divide-y lg:divide-y-0 lg:divide-x divide-hairline bg-surface-soft/5">
        <div class="flex flex-col gap-5 p-8 md:p-12 lg:p-14">
          <Badge variant="violet">Our Vision</Badge>
          <h2 class="type-display-sm tracking-tight text-ink">To obliterate information asymmetry in financial markets</h2>
          <p class="type-body-md text-muted leading-relaxed">We envision a future where every serious trader — regardless of capital size — has access to the same institutional-grade intelligence that hedge funds and prop desks use. AI, quantitative research, and engineering converge to level the playing field.</p>
        </div>
        <div class="flex flex-col gap-5 p-8 md:p-12 lg:p-14">
          <Badge variant="pink">Our Mission</Badge>
          <h2 class="type-display-sm tracking-tight text-ink">Solving complex trading problems through AI innovation</h2>
          <p class="type-body-md text-muted leading-relaxed">To develop intelligent products that empower traders with superior market intelligence — fusing multi-agent AI systems, real-time data pipelines, and quantitative models into a single conviction engine.</p>
        </div>
      </div>
    </Container>
  </section>

  <!-- Philosophy -->
  <section class="py-16 md:py-20 bg-canvas transition-colors duration-300">
    <Container>
      <div class="max-w-[800px] mx-auto text-center mb-12">
        <Badge variant="orange" class="mb-4">Our Philosophy</Badge>
        <h2 class="type-display-lg leading-[1.1] tracking-tight text-ink">Research before product</h2>
        <p class="type-body-md text-muted mt-4 max-w-[600px] mx-auto leading-relaxed">Every innovation at Strat Ai follows the same foundation. We never build without understanding first.</p>
      </div>
    </Container>
    <Container size="wide" class="!px-0">
      <div class="border-y border-hairline bg-surface-soft/5">
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 divide-y md:divide-y-0 divide-x divide-hairline">
          {[
            { step: '01', label: 'Research', desc: 'Deep domain study' },
            { step: '02', label: 'Data', desc: 'Market & financial data' },
            { step: '03', label: 'Analysis', desc: 'Quantitative modeling' },
            { step: '04', label: 'AI Modeling', desc: 'Machine learning' },
            { step: '05', label: 'Engineering', desc: 'Scalable systems' },
            { step: '06', label: 'Product', desc: 'User-facing delivery' },
          ].map((item) => (
            <div class="flex flex-col gap-2 p-6 md:p-8 text-center">
              <span class="type-caption text-badge-emerald font-bold">{item.step}</span>
              <h3 class="type-title-sm text-ink">{item.label}</h3>
              <p class="type-body-sm text-muted-soft">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </Container>
  </section>

  <!-- Research Domains -->
  <section class="py-16 md:py-20 bg-canvas transition-colors duration-300">
    <Container>
      <div class="max-w-[800px] mx-auto text-center mb-12">
        <Badge variant="emerald" class="mb-4">Research Domains</Badge>
        <h2 class="type-display-lg leading-[1.1] tracking-tight text-ink">What we research</h2>
      </div>
    </Container>
    <Container size="wide" class="!px-0">
      <div class="grid grid-cols-1 md:grid-cols-2 border-y border-hairline divide-y md:divide-y-0 md:divide-x divide-hairline bg-surface-soft/5">
        <div class="flex flex-col gap-4 p-8 md:p-10">
          <h3 class="type-title-lg text-ink flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-badge-orange"></span> Financial Markets</h3>
          <ul class="list-none grid grid-cols-2 gap-2">
            {['Indian Stock Market', 'Futures & Options', 'Crypto Markets', 'Market Structure', 'Price Action', 'Order Flow', 'Volatility', 'Risk Management'].map(item => (
              <li class="type-body-sm text-muted flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-muted-soft shrink-0"></span>{item}</li>
            ))}
          </ul>
        </div>
        <div class="flex flex-col gap-4 p-8 md:p-10">
          <h3 class="type-title-lg text-ink flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-badge-pink"></span> Artificial Intelligence</h3>
          <ul class="list-none grid grid-cols-2 gap-2">
            {['Financial AI', 'Machine Learning', 'Large Language Models', 'AI Agents', 'Predictive Analytics', 'NLP for Markets'].map(item => (
              <li class="type-body-sm text-muted flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-muted-soft shrink-0"></span>{item}</li>
            ))}
          </ul>
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 border-b border-hairline divide-y md:divide-y-0 md:divide-x divide-hairline bg-surface-soft/5">
        <div class="flex flex-col gap-4 p-8 md:p-10">
          <h3 class="type-title-lg text-ink flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-badge-violet"></span> Quantitative Research</h3>
          <ul class="list-none grid grid-cols-2 gap-2">
            {['Statistical Modeling', 'Strategy Dev', 'Market Behavior', 'Probability Models', 'Performance Analysis', 'Risk Optimization'].map(item => (
              <li class="type-body-sm text-muted flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-muted-soft shrink-0"></span>{item}</li>
            ))}
          </ul>
        </div>
        <div class="flex flex-col gap-4 p-8 md:p-10">
          <h3 class="type-title-lg text-ink flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-badge-emerald"></span> Engineering</h3>
          <ul class="list-none grid grid-cols-2 gap-2">
            {['Scalable Systems', 'High-Performance Infra', 'Cloud Architecture', 'Data Engineering', 'APIs & Services', 'Automation'].map(item => (
              <li class="type-body-sm text-muted flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-muted-soft shrink-0"></span>{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </Container>
  </section>

  <!-- Values -->
  <section class="py-16 md:py-20 bg-canvas transition-colors duration-300">
    <Container>
      <div class="max-w-[800px] mx-auto text-center mb-12">
        <Badge variant="pink" class="mb-4">Our Values</Badge>
        <h2 class="type-display-lg leading-[1.1] tracking-tight text-ink">What drives us</h2>
      </div>
    </Container>
    <Container size="wide" class="!px-0">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 border-y border-hairline divide-y md:divide-y-0 divide-x divide-hairline bg-surface-soft/5">
        {[
          { icon: 'search', title: 'Research Driven', desc: 'Every product begins with research, not assumptions. We study markets deeply before building.' },
          { icon: 'brain', title: 'AI Powered', desc: 'Artificial intelligence is integrated into every layer of our products for superior insights.' },
          { icon: 'layers', title: 'Built for Scale', desc: 'Engineered using modern cloud infrastructure and scalable technologies for global reach.' },
          { icon: 'chart', title: 'Long-Term Vision', desc: 'We are building an ecosystem of intelligent financial technologies, one product at a time.' },
        ].map((value) => (
          <div class="flex flex-col gap-4 p-8 md:p-10 hover:bg-surface-soft/10 transition-colors duration-300">
            <div class="w-10 h-10 rounded-lg bg-badge-emerald/10 flex items-center justify-center">
              <Icon name={value.icon} class="w-5 h-5 text-badge-emerald" />
            </div>
            <h3 class="type-title-md text-ink">{value.title}</h3>
            <p class="type-body-sm text-muted leading-relaxed">{value.desc}</p>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-20 bg-canvas transition-colors duration-300">
    <Container size="wide" class="!px-0">
      <div class="border-y border-hairline bg-surface-soft/5 p-8 md:p-12 lg:p-16 text-center">
        <h2 class="type-display-md tracking-tight text-ink mb-4">Join our journey</h2>
        <p class="type-body-md text-muted max-w-[500px] mx-auto mb-8 leading-relaxed">We're building the future of trading intelligence. Be among the first to experience AI-powered conviction.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <Button variant="primary" size="lg" href="/contact" class="!rounded-full px-8">Get in Touch</Button>
          <Button variant="secondary" size="lg" href="/#features" class="!rounded-full px-8">Explore Strat AI</Button>
        </div>
      </div>
    </Container>
  </section>
</PageLayout>
