import Container from '@/components/ui/Container.astro';
import Prose from '@/components/ui/Prose.astro';
---
<PageLayout title="Disclaimer" description="Important risk disclosures and disclaimers for Strat Ai services." badge="Legal" badgeVariant="default" breadcrumbs={[{ label: 'Disclaimer' }]}>
  <section class="py-16 md:py-20 bg-canvas transition-colors duration-300">
    <Container size="narrow">
      <Prose>
        <p class="text-muted-soft type-body-sm">Last updated: June 26, 2026</p>
        <h2>General Disclaimer</h2>
        <p>The information provided on this website and through the Strat Ai terminal by Trading & Research Wing ("Trading & Research Wing") is for <strong>general informational and educational purposes only</strong>. Nothing on this website constitutes financial advice, investment advice, trading advice, or any other form of professional advice.</p>
        <h2>Not Financial Advice</h2>
        <blockquote>Strat Ai does not provide personalized financial, investment, legal, or tax advice. All quantitative market analysis, insights, trade validations, and research reports are provided strictly for informational purposes and should not be relied upon as the sole basis for any financial decision.</blockquote>
        <p>Before making any investment or trading decision, you should consult with a qualified financial advisor who is aware of your individual financial situation and risk tolerance.</p>
        <h2>Trading Risk Warning</h2>
        <p><strong>Trading in financial markets carries a high level of risk and may not be suitable for all investors.</strong></p>
        <p>Key risks include:</p>
        <ul><li><strong>Market Risk:</strong> Prices can fluctuate rapidly due to market conditions, economic events, and geopolitical factors.</li><li><strong>Leverage Risk:</strong> F&O trading involves leverage, which can amplify both gains and losses.</li><li><strong>Liquidity Risk:</strong> Some instruments may have limited liquidity.</li><li><strong>Technology Risk:</strong> Software systems may experience errors or delays.</li><li><strong>Loss of Capital:</strong> You may lose some or all of your invested capital. Never trade with money you cannot afford to lose.</li></ul>
        <h2>Past Performance Disclaimer</h2>
        <p>Past performance is not indicative of future results. Any historical data, backtesting results, or performance metrics are for illustrative purposes only.</p>
        <h2>Quantitative Model and Technology Disclaimer</h2>
        <p>Strat Ai utilizes quantitative models and historical analysis tools. You acknowledge that:</p>
        <ul><li>Quantitative models may produce inaccurate or misleading outputs</li><li>Model-generated insights are probabilistic assessments, not certainties</li><li>Models are trained on historical data and may not perform well under novel conditions</li><li>The terminal should be used as one tool among many, not as a sole source of truth</li></ul>
        <h2>Indian Market Specific Disclosures</h2>
        <p>Trading & Research Wing is not registered with the Securities and Exchange Board of India (SEBI) as an investment advisor, research analyst, or portfolio manager. Our services do not constitute SEBI-regulated investment advisory or research analyst services.</p>
        <h2>No Guarantee of Results</h2>
        <p>Trading & Research Wing makes no representations or warranties regarding the accuracy, reliability, or completeness of any information provided. We do not guarantee any specific trading results or outcomes.</p>
        <h2>Limitation of Liability</h2>
        <p>Under no circumstances shall Trading & Research Wing, its founders, employees, partners, or affiliates be held liable for any direct, indirect, incidental, special, or consequential damages arising from your use of our services, including financial losses from trading decisions influenced by our platform.</p>
        <h2>Your Responsibility</h2>
        <p>You are solely responsible for evaluating the merits and risks associated with any trading or investment decision. By using our services, you acknowledge that you understand these risks and accept full responsibility.</p>
        <hr />
        <p>If you have questions about this disclaimer, please contact us at <a href="mailto:legal@stratai.live">legal@stratai.live</a>.</p>
