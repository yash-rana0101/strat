---
/**
 * Download — App download page with Desktop (Windows/Mac), Web, and Mobile.
 */
import PageLayout from '@/layouts/PageLayout.astro';
import Container from '@/components/ui/Container.astro';
import Badge from '@/components/ui/Badge.astro';
import Button from '@/components/ui/Button.astro';
import Icon from '@/components/ui/Icon.astro';
---
<PageLayout title="Download Strat Ai" description="Get Strat Ai on your preferred platform — Desktop, Web, and Mobile." badge="Get the App" badgeVariant="emerald" breadcrumbs={[{ label: 'Download' }]}>

  <!-- Desktop Apps — Primary -->
  <section class="py-16 md:py-20 bg-canvas transition-colors duration-300">
    <Container>
      <div class="max-w-[800px] mx-auto text-center mb-12">
        <Badge variant="emerald" class="mb-4">Desktop App</Badge>
        <h2 class="type-display-lg leading-[1.1] tracking-tight text-ink">Native desktop experience</h2>
        <p class="type-body-md text-muted mt-4">Full-featured desktop app with real-time charts, system tray notifications, and keyboard shortcuts for power users.</p>
      </div>
    </Container>
    <Container size="wide" class="!px-0">
      <div class="grid grid-cols-1 md:grid-cols-2 border-y border-hairline divide-y md:divide-y-0 md:divide-x divide-hairline bg-surface-soft/5">
        <!-- Windows -->
        <div class="p-8 md:p-12 flex flex-col items-center text-center gap-6">
          <div class="w-20 h-20 rounded-2xl bg-badge-violet/10 flex items-center justify-center">
            <svg viewBox="0 0 24 24" width="40" height="40" fill="currentColor" class="text-badge-violet">
              <path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801" />
            </svg>
          </div>
          <div>
            <h3 class="type-title-lg text-ink font-bold">Windows</h3>
            <p class="type-body-sm text-muted mt-2">Native Windows app with system tray integration, global hotkeys, and multi-monitor support.</p>
          </div>
          <div class="flex flex-col gap-2 w-full max-w-[280px] mt-auto">
            <Button variant="primary" size="lg" href="#" class="!rounded-full w-full justify-center gap-2">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801" /></svg>
              Download for Windows
            </Button>
            <span class="text-[11px] text-muted-soft">Windows 10+ · 64-bit · v1.4.0 · 85 MB</span>
          </div>
        </div>

        <!-- macOS -->
        <div class="p-8 md:p-12 flex flex-col items-center text-center gap-6">
          <div class="w-20 h-20 rounded-2xl bg-surface-card border border-hairline/50 flex items-center justify-center">
            <svg viewBox="0 0 24 24" width="40" height="40" fill="currentColor" class="text-ink">
              <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z" />
            </svg>
          </div>
          <div>
            <h3 class="type-title-lg text-ink font-bold">macOS</h3>
            <p class="type-body-sm text-muted mt-2">Universal binary for Apple Silicon and Intel. Menu bar integration, Spotlight search, and native notifications.</p>
          </div>
          <div class="flex flex-col gap-2 w-full max-w-[280px] mt-auto">
            <Button variant="primary" size="lg" href="#" class="!rounded-full w-full justify-center gap-2">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z" /></svg>
              Download for Mac
            </Button>
            <span class="text-[11px] text-muted-soft">macOS 13+ · Universal (ARM + Intel) · v1.4.0 · 92 MB</span>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- Web App — Coming Soon -->
  <section class="py-16 md:py-20 bg-canvas transition-colors duration-300">
    <Container size="wide" class="!px-0">
      <div class="border-y border-hairline bg-surface-soft/5 p-8 md:p-12 lg:p-16">
        <div class="max-w-[800px] mx-auto text-center flex flex-col items-center gap-5">
          <div class="w-16 h-16 rounded-2xl bg-badge-emerald/15 flex items-center justify-center">
            <Icon name="compass" size={32} class="text-badge-emerald" />
          </div>
          <Badge variant="orange">Coming Soon</Badge>
          <h2 class="type-display-sm tracking-tight text-ink">Web App</h2>
          <p class="type-body-md text-muted max-w-[500px]">Access Strat Ai directly from your browser. No installation required. Works on all modern browsers — Chrome, Firefox, Safari, Edge.</p>
          <Button variant="secondary" size="lg" class="!rounded-full px-8 cursor-not-allowed opacity-60">Coming Soon</Button>
        </div>
      </div>
    </Container>
  </section>

  <!-- Mobile — Coming Soon -->
  <section class="py-16 md:py-20 bg-canvas transition-colors duration-300">
    <Container>
      <div class="max-w-[800px] mx-auto text-center mb-12">
        <Badge variant="orange" class="mb-4">Coming Soon</Badge>
        <h2 class="type-display-lg leading-[1.1] tracking-tight text-ink">Mobile apps</h2>
        <p class="type-body-md text-muted mt-4">Native Android and iOS apps are in active development.</p>
      </div>
    </Container>
    <Container size="wide" class="!px-0">
      <div class="grid grid-cols-1 md:grid-cols-2 border-y border-hairline divide-y md:divide-y-0 md:divide-x divide-hairline bg-surface-soft/5">
        <!-- Android -->
        <div class="p-8 md:p-12 flex flex-col items-center text-center gap-5">
          <div class="w-16 h-16 rounded-2xl bg-badge-emerald/10 flex items-center justify-center">
            <svg viewBox="0 0 24 24" width="32" height="32" fill="currentColor" class="text-badge-emerald">
              <path d="M17.523 15.341a.96.96 0 0 0 .96-.96V8.076a.96.96 0 1 0-1.92 0v6.305a.96.96 0 0 0 .96.96m-11.046 0a.96.96 0 0 0 .96-.96V8.076a.96.96 0 1 0-1.92 0v6.305a.96.96 0 0 0 .96.96M5.782 7.2h12.436a3.36 3.36 0 0 0-3.262-2.592h-.132l1.053-1.668a.36.36 0 0 0-.606-.387L14.14 4.608h-4.28L8.73 2.553a.36.36 0 1 0-.606.387l1.053 1.668h-.132A3.36 3.36 0 0 0 5.782 7.2m0 .96v6.24a1.92 1.92 0 0 0 1.92 1.92h.72v2.16a.96.96 0 1 0 1.92 0v-2.16h1.316v2.16a.96.96 0 1 0 1.92 0v-2.16h.72a1.92 1.92 0 0 0 1.92-1.92V8.16z"/>
            </svg>
          </div>
          <div>
            <h3 class="type-title-lg text-ink font-bold">Android</h3>
            <p class="type-body-sm text-muted mt-2">Native Android app with real-time notifications, offline charts, and biometric authentication.</p>
          </div>
          <div class="flex flex-col gap-2 w-full max-w-[280px] mt-auto">
            <Button variant="secondary" size="lg" class="!rounded-full w-full justify-center cursor-not-allowed opacity-60">Coming Soon</Button>
            <span class="text-[11px] text-muted-soft">Android 12+</span>
          </div>
        </div>

        <!-- iOS -->
        <div class="p-8 md:p-12 flex flex-col items-center text-center gap-5">
          <div class="w-16 h-16 rounded-2xl bg-surface-card border border-hairline/50 flex items-center justify-center">
            <svg viewBox="0 0 24 24" width="32" height="32" fill="currentColor" class="text-ink">
              <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z" />
            </svg>
          </div>
          <div>
            <h3 class="type-title-lg text-ink font-bold">iOS</h3>
            <p class="type-body-sm text-muted mt-2">Designed for iPhone and iPad. Widgets, haptics, and Apple Watch conviction score alerts.</p>
          </div>
          <div class="flex flex-col gap-2 w-full max-w-[280px] mt-auto">
            <Button variant="secondary" size="lg" class="!rounded-full w-full justify-center cursor-not-allowed opacity-60">Coming Soon</Button>
            <span class="text-[11px] text-muted-soft">iOS 17+</span>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- System Requirements -->
  <section class="py-16 md:py-20 bg-canvas transition-colors duration-300">
    <Container size="wide" class="!px-0">
      <div class="border-y border-hairline bg-surface-soft/5 p-8 md:p-12 lg:p-16">
        <div class="max-w-[800px] mx-auto">
          <Badge variant="default" class="mb-4">System Requirements</Badge>
          <h2 class="type-display-sm tracking-tight text-ink mb-6">Minimum requirements</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div class="flex flex-col gap-3">
              <h4 class="type-title-sm text-ink flex items-center gap-2">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" class="text-badge-violet"><path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801" /></svg>
                Windows
              </h4>
              <ul class="list-none flex flex-col gap-2">
                {['Windows 10 (64-bit)+', '4 GB RAM', '200 MB disk space', '.NET Runtime 8.0+'].map(r => (
                  <li class="flex items-center gap-2 type-body-sm text-muted"><span class="w-1.5 h-1.5 rounded-full bg-badge-violet"></span>{r}</li>
                ))}
              </ul>
            </div>
            <div class="flex flex-col gap-3">
              <h4 class="type-title-sm text-ink flex items-center gap-2">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z" /></svg>
                macOS
              </h4>
              <ul class="list-none flex flex-col gap-2">
                {['macOS 13 Ventura+', 'Apple Silicon or Intel', '4 GB RAM', '250 MB disk space'].map(r => (
                  <li class="flex items-center gap-2 type-body-sm text-muted"><span class="w-1.5 h-1.5 rounded-full bg-ink"></span>{r}</li>
                ))}
              </ul>
            </div>
            <div class="flex flex-col gap-3">
              <h4 class="type-title-sm text-ink flex items-center gap-2">
                <Icon name="compass" size={14} class="text-badge-emerald" />
                Web Browser
              </h4>
              <ul class="list-none flex flex-col gap-2">
                {['Chrome 100+', 'Firefox 100+', 'Safari 16+', 'Stable internet (5 Mbps+)'].map(r => (
                  <li class="flex items-center gap-2 type-body-sm text-muted"><span class="w-1.5 h-1.5 rounded-full bg-badge-emerald"></span>{r}</li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </Container>
  </section>
</PageLayout>
