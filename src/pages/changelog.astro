---
/**
 * Changelog — Product updates and release history.
 */
import PageLayout from '@/layouts/PageLayout.astro';
import Container from '@/components/ui/Container.astro';
import Badge from '@/components/ui/Badge.astro';

const releases = [
  { version: 'v1.4.0', date: 'June 25, 2026', tag: 'Latest', tagVariant: 'emerald' as const, changes: ['New volatility skew visualization on options chain', 'Improved data feed refresh rate and responsiveness', 'Enhanced capital preservation model parameters'] },
  { version: 'v1.3.0', date: 'June 10, 2026', tag: 'Feature', tagVariant: 'violet' as const, changes: ['Trend projection overlay — mathematical regression analysis', 'Custom timeframe support (1m, 5m, 15m, 1h, 4h, 1D)', 'Improved news sentiment parsing and scoring', 'Dark/Light theme toggle'] },
  { version: 'v1.2.0', date: 'May 28, 2026', tag: 'Feature', tagVariant: 'violet' as const, changes: ['Options chain metrics with Open Interest and volume analysis', 'Open Interest heatmap and put-call ratio overlays', 'Max pain calculation visualization', 'API v1 access for Pro users'] },
  { version: 'v1.1.0', date: 'May 15, 2026', tag: 'Improvement', tagVariant: 'orange' as const, changes: ['Redesigned quantitative trading terminal UI', 'Added conviction score detail breakdown panels', 'Real-time data synchronization support', 'Bug fixes: chart rendering on mobile browsers'] },
  { version: 'v1.0.0', date: 'May 1, 2026', tag: 'Launch', tagVariant: 'pink' as const, changes: ['Initial public beta launch', 'Consensus score framework evaluating multiple analysis dimensions', '16 technical metrics computed in real-time', 'Full NSE F&O market coverage'] },
];
---
<PageLayout title="Changelog" description="Product updates, new features, and improvements to the Strat Ai platform." badge="Updates" badgeVariant="emerald" breadcrumbs={[{ label: 'Changelog' }]}>
  <section class="py-16 md:py-20 bg-canvas transition-colors duration-300">
    <Container size="narrow">
      <div class="flex flex-col gap-0">
        {releases.map((release, i) => (
          <div class="relative pl-8 pb-12 last:pb-0">
            <div class="absolute left-0 top-1.5 w-3 h-3 rounded-full bg-brand-accent border-2 border-canvas z-10"></div>
            {i < releases.length - 1 && <div class="absolute left-[5px] top-4 bottom-0 w-[1px] bg-hairline"></div>}
            <div class="flex flex-wrap items-center gap-3 mb-3">
              <h3 class="type-title-md text-ink font-bold">{release.version}</h3>
              <Badge variant={release.tagVariant}>{release.tag}</Badge>
              <span class="text-xs text-muted-soft">{release.date}</span>
            </div>
            <ul class="list-none flex flex-col gap-2">
              {release.changes.map((change) => (
                <li class="flex items-start gap-2.5">
                  <span class="w-1.5 h-1.5 rounded-full bg-muted-soft mt-2 shrink-0"></span>
                  <span class="type-body-sm text-muted">{change}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </Container>
  </section>
</PageLayout>
