---
/**
 * Careers — Open positions and culture page.
 */
import PageLayout from '@/layouts/PageLayout.astro';
import Container from '@/components/ui/Container.astro';
import Badge from '@/components/ui/Badge.astro';
import Button from '@/components/ui/Button.astro';
import Icon from '@/components/ui/Icon.astro';

const openings = [
  { title: 'ML Engineer — Financial AI', team: 'AI Research', type: 'Full-time', location: 'Remote (India)', desc: 'Design and deploy ML models for real-time market analysis, options pricing, and anomaly detection across Indian F&O markets.' },
  { title: 'Quantitative Researcher', team: 'Research', type: 'Full-time', location: 'Remote (India)', desc: 'Build predictive models, backtest trading strategies, and develop statistical frameworks for the Strat Ai conviction engine.' },
  { title: 'Senior Backend Engineer (Rust)', team: 'Engineering', type: 'Full-time', location: 'Remote (India)', desc: 'Build the high-performance data pipeline powering sub-50ms signal latency — from tick ingestion to indicator computation.' },
  { title: 'Frontend Engineer (Astro / React)', team: 'Engineering', type: 'Full-time', location: 'Remote (India)', desc: 'Craft the trading interface — real-time charts, AI dashboards, and responsive layouts for web and mobile.' },
  { title: 'Product Designer', team: 'Design', type: 'Full-time / Contract', location: 'Remote (India)', desc: 'Design intuitive, data-dense trading interfaces that make institutional-grade intelligence accessible to retail traders.' },
];

const perks = [
  { icon: 'zap', title: 'Remote-First', desc: 'Work from anywhere in India with async-first collaboration.' },
  { icon: 'chart', title: 'Equity Options', desc: 'Early employees receive meaningful equity stakes in the company.' },
  { icon: 'brain', title: 'Research Time', desc: '20% time for personal research projects in AI or quantitative finance.' },
  { icon: 'layers', title: 'Learning Budget', desc: '₹50K annual budget for courses, conferences, and books.' },
];
---
<PageLayout title="Careers" description="Join the team building AI-powered trading intelligence for the next generation of Indian traders." badge="We're Hiring" badgeVariant="emerald" breadcrumbs={[{ label: 'Careers' }]}>
  <!-- Culture -->
  <section class="py-16 md:py-20 bg-canvas transition-colors duration-300">
    <Container size="wide" class="!px-0">
      <div class="grid grid-cols-1 lg:grid-cols-2 border-y border-hairline divide-y lg:divide-y-0 lg:divide-x divide-hairline bg-surface-soft/5">
        <div class="flex flex-col gap-5 p-8 md:p-12 lg:p-14">
          <Badge variant="violet">Our Culture</Badge>
          <h2 class="type-display-sm tracking-tight text-ink">Small team, outsized impact</h2>
          <p class="type-body-md text-muted leading-relaxed">We're a lean, research-driven team of engineers, quants, and designers obsessed with obliterating information asymmetry in Indian financial markets. Every person here ships production code, publishes research, and moves the needle.</p>
        </div>
        <div class="grid grid-cols-2 divide-x divide-y divide-hairline">
          {perks.map((perk) => (
            <div class="flex flex-col gap-2 p-6 md:p-8 hover:bg-surface-soft/10 transition-colors">
              <div class="w-8 h-8 rounded-lg bg-badge-emerald/10 flex items-center justify-center"><Icon name={perk.icon} class="w-4 h-4 text-badge-emerald" /></div>
              <h4 class="type-title-sm text-ink">{perk.title}</h4>
              <p class="type-body-sm text-muted-soft">{perk.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </Container>
  </section>

  <!-- Open Roles -->
  <section class="py-16 md:py-20 bg-canvas transition-colors duration-300">
    <Container>
      <div class="max-w-[800px] mx-auto text-center mb-12">
        <Badge variant="emerald" class="mb-4">Open Positions</Badge>
        <h2 class="type-display-lg leading-[1.1] tracking-tight text-ink">Current openings</h2>
        <p class="type-body-md text-muted mt-4">We're looking for exceptional people who want to build at the intersection of AI and finance.</p>
      </div>
    </Container>
    <Container size="wide" class="!px-0">
      <div class="border-y border-hairline divide-y divide-hairline bg-surface-soft/5">
        {openings.map((role) => (
          <div class="p-6 md:p-8 flex flex-col md:flex-row md:items-center gap-4 md:gap-8 hover:bg-surface-soft/10 transition-colors group">
            <div class="flex-1">
              <h3 class="type-title-md text-ink group-hover:text-brand-accent transition-colors">{role.title}</h3>
              <p class="type-body-sm text-muted mt-1">{role.desc}</p>
            </div>
            <div class="flex flex-wrap items-center gap-2 shrink-0">
              <span class="px-2.5 py-1 text-[11px] font-medium bg-surface-card border border-hairline/60 rounded-full text-muted">{role.team}</span>
              <span class="px-2.5 py-1 text-[11px] font-medium bg-surface-card border border-hairline/60 rounded-full text-muted">{role.type}</span>
              <span class="px-2.5 py-1 text-[11px] font-medium bg-surface-card border border-hairline/60 rounded-full text-muted">{role.location}</span>
            </div>
            <Button variant="secondary" size="sm" href={`mailto:careers@stratai.live?subject=Application: ${role.title}`} class="!rounded-full shrink-0">Apply</Button>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-20 bg-canvas transition-colors duration-300">
    <Container size="wide" class="!px-0">
      <div class="border-y border-hairline bg-surface-soft/5 p-8 md:p-12 lg:p-16 text-center">
        <h2 class="type-display-md tracking-tight text-ink mb-4">Don't see your role?</h2>
        <p class="type-body-md text-muted max-w-[500px] mx-auto mb-8">We're always looking for exceptional talent. Send us your resume and tell us how you'd contribute.</p>
        <Button variant="primary" size="lg" href="mailto:careers@stratai.live" class="!rounded-full px-8">Send Resume</Button>
      </div>
    </Container>
  </section>
</PageLayout>
