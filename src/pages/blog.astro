---
/**
 * Blog Index — Blog listing page.
 */
import PageLayout from '@/layouts/PageLayout.astro';
import Container from '@/components/ui/Container.astro';
import Badge from '@/components/ui/Badge.astro';

const posts = [
  { title: 'How Multi-Variable Consensus Eliminates Confirmation Bias', date: 'June 24, 2026', tag: 'Research', tagVariant: 'violet' as const, excerpt: 'Single-source analysis is inherently fragile. We explain how Strat Ai\'s unified evaluation framework generates conviction scores resistant to false indicators.' },
  { title: 'Understanding Trend Projection Overlays: Mapping Volatility Zones', date: 'June 18, 2026', tag: 'Technical', tagVariant: 'emerald' as const, excerpt: 'A detailed look at mathematical trend projection overlays on F&O charts, explaining how trend boundaries work and how to leverage them.' },
  { title: 'The Importance of Real-Time Ingestion in Option Chains', date: 'June 10, 2026', tag: 'F&O', tagVariant: 'orange' as const, excerpt: 'How immediate strike-ordered feeds and open interest synchronization help spot intraday shifts in market support and resistance.' },
  { title: 'Open Interest Heatmaps: Reading Volume Profiles in Nifty Options', date: 'June 3, 2026', tag: 'F&O', tagVariant: 'pink' as const, excerpt: 'How to interpret OI buildup patterns, PCR shifts, and max pain levels to identify key participant positioning before major moves.' },
  { title: 'Decoding Conviction Scores: Fusing Multi-Variable Inputs', date: 'May 28, 2026', tag: 'Methodology', tagVariant: 'violet' as const, excerpt: 'A walkthrough of our evaluation pipeline — from raw market data and indicators to sentiment analysis and unified consensus.' },
  { title: 'Why Disciplined Strategy & Research is the Real Edge in Indian Markets', date: 'May 20, 2026', tag: 'Philosophy', tagVariant: 'emerald' as const, excerpt: 'Traders often lose due to emotional bias and incomplete access to tools. How professional-grade research and capital preservation strategies level the playing field.' },
];
---
<PageLayout title="Blog" description="Research, strategies, and market insights from the Trading and Research Wing." badge="Insights" badgeVariant="emerald" breadcrumbs={[{ label: 'Blog' }]}>
  <section class="py-16 md:py-20 bg-canvas transition-colors duration-300">
    <Container size="wide" class="!px-0">
      <div class="border-y border-hairline divide-y divide-hairline bg-surface-soft/5">
        {posts.map((post) => (
          <article class="p-6 md:p-8 lg:p-10 flex flex-col gap-3 hover:bg-surface-soft/10 transition-colors group cursor-pointer">
            <div class="flex items-center gap-3">
              <Badge variant={post.tagVariant}>{post.tag}</Badge>
              <span class="text-xs text-muted-soft">{post.date}</span>
            </div>
            <h2 class="type-title-lg text-ink group-hover:text-brand-accent transition-colors leading-snug">{post.title}</h2>
            <p class="type-body-md text-muted max-w-[700px]">{post.excerpt}</p>
          </article>
        ))}
      </div>
    </Container>
  </section>
</PageLayout>
