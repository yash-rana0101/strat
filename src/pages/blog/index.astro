---
/**
 * Blog Listing Page — Grid of blog posts with category filtering.
 */

import PageLayout from '@/layouts/PageLayout.astro';
import Container from '@/components/ui/Container.astro';
import BlogCard from '@/components/ui/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const categories = [...new Set(posts.map(p => p.data.category))];
---

<PageLayout
  title="Blog"
  description="Insights on quantitative research, financial markets, and trading intelligence from the Trading and Research Wing."
  badge="Insights"
  badgeVariant="emerald"
  breadcrumbs={[{ label: 'Blog' }]}
>
  <!-- Category Filters -->
  <section class="py-8 bg-canvas transition-colors duration-300">
    <Container>
      <div class="flex flex-wrap gap-2">
        <span class="px-4 py-2 rounded-full bg-primary text-on-primary type-body-sm font-medium cursor-pointer">
          All Posts
        </span>
        {categories.map((cat) => (
          <span class="px-4 py-2 rounded-full border border-hairline text-muted type-body-sm font-medium hover:bg-surface-card hover:text-ink cursor-pointer transition-colors duration-200">
            {cat}
          </span>
        ))}
      </div>
    </Container>
  </section>

  <!-- Posts Grid -->
  <section class="pb-16 md:pb-20 bg-canvas transition-colors duration-300">
    <Container size="wide" class="!px-0">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 border-y border-hairline divide-y md:divide-y-0 bg-surface-soft/5">
        {posts.map((post, i) => (
          <div class:list={[
            i < posts.length - (posts.length % 3 || 3) ? 'border-b border-hairline' : '',
            'md:border-r md:border-hairline md:last:border-r-0',
            // Reset right border for every 3rd item on lg
            (i + 1) % 3 === 0 ? 'lg:border-r-0' : '',
          ]}>
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              category={post.data.category}
              slug={post.id}
            />
          </div>
        ))}
      </div>

      {posts.length === 0 && (
        <div class="border-y border-hairline bg-surface-soft/5 p-16 text-center">
          <p class="type-body-md text-muted">No blog posts yet. Check back soon!</p>
        </div>
      )}
    </Container>
  </section>
</PageLayout>
