---
/**
 * Homepage — Strat Ai Landing Page.
 * Thin orchestration layer composing all sections.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/sections/Hero.astro';
import UseCases from '@/components/sections/UseCases.astro';
import HowItWorks from '@/components/sections/HowItWorks.astro';
import Features from '@/components/sections/Features.astro';
import Stats from '@/components/sections/Stats.astro';
import Pricing from '@/components/sections/Pricing.astro';
import FAQ from '@/components/sections/FAQ.astro';
import Security from '@/components/sections/Security.astro';
import CTA from '@/components/sections/CTA.astro';
import Container from '@/components/ui/Container.astro';
import Blog from '@/components/sections/Blog.astro';

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Strat AI',
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'Desktop, Web',
  description: 'Institutional-grade quantitative trading intelligence terminal built by the Trading and Research Wing (https://www.tradingrw.com/) for Indian F&O markets.',
  featureList: [
    'Multi-variable Consensus',
    'Trend Exhaustion Predictor',
    'Real-Time Option Chains',
    'Risk Verification Auditor',
    'Capital Preservation Mode',
  ],
  audience: { '@type': 'Audience', audienceType: 'Traders, Quant Analysts, Risk Managers' },
};
---

<BaseLayout
  title="Strat Ai — Quantitative Trading Terminal for NSE F&O"
  description="Institutional-grade quantitative trading intelligence platform built by the Trading and Research Wing. Fuse real-time indicators, option chains, and market sentiment into a single conviction score."
  jsonLd={productSchema}
>
  <Hero />
  
  <!-- Hero Product Preview Image Section -->
  <section class="pt-6 md:pt-8 pb-16 md:pb-24 bg-canvas relative z-10 transition-colors duration-300">
    <Container>
      <div class="w-full rounded-2xl overflow-hidden border border-hairline/80 shadow-[0_20px_50px_rgba(16,185,129,0.08)] bg-surface-card reveal reveal-scale-up">
        <img 
          src="/hero/hero-dark.png" 
          alt="Strat Ai Terminal Dashboard Preview" 
          class="w-full h-auto hero-image-dark"
          loading="eager"
        />
        <img 
          src="/hero/hero-light.png" 
          alt="Strat Ai Terminal Dashboard Preview" 
          class="w-full h-auto hero-image-light"
          loading="eager"
        />
      </div>

<style>
  .hero-image-dark {
    display: block;
  }
  .hero-image-light {
    display: none;
  }
  
  :global([data-theme="light"]) .hero-image-dark {
    display: none;
  }
  :global([data-theme="light"]) .hero-image-light {
    display: block;
  }
</style>
    </Container>
  </section>

  <UseCases />
  <HowItWorks />
  <Features />
  <Stats />
  <Security />
  <Pricing />
  <Blog />
  <FAQ />
  <CTA />
</BaseLayout>
