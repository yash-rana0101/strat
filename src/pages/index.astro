---
/**
 * Homepage — Strat Ai Landing Page.
 * Thin orchestration layer composing all sections.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/sections/Hero.astro';
import UseCases from '@/components/sections/UseCases.astro';
import HowItWorks from '@/components/sections/HowItWorks.astro';
import Features from '@/components/sections/Features.astro';
import Stats from '@/components/sections/Stats.astro';
import Pricing from '@/components/sections/Pricing.astro';
import FAQ from '@/components/sections/FAQ.astro';
import Security from '@/components/sections/Security.astro';
import CTA from '@/components/sections/CTA.astro';

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Strat AI',
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'Desktop, Web',
  description: 'Institutional-grade quantitative trading intelligence terminal built by the Trading and Research Wing (https://tradingrw.com) for Indian F&O markets.',
  featureList: [
    'Multi-variable Consensus',
    'Trend Exhaustion Predictor',
    'Real-Time Option Chains',
    'Risk Verification Auditor',
    'Capital Preservation Mode',
  ],
  audience: { '@type': 'Audience', audienceType: 'Traders, Quant Analysts, Risk Managers' },
};
---

<BaseLayout
  title="Strat Ai — Quantitative Trading Terminal for NSE F&O"
  description="Institutional-grade quantitative trading intelligence platform built by the Trading and Research Wing. Fuse real-time indicators, option chains, and market sentiment into a single conviction score."
  jsonLd={productSchema}
>
  <Hero />
  <UseCases />
  <HowItWorks />
  <Features />
  <Stats />
  <Security />
  <Pricing />
  <FAQ />
  <CTA />
</BaseLayout>
