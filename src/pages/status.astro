---
/**
 * Status — System status page showing service health.
 */
import PageLayout from '@/layouts/PageLayout.astro';
import Container from '@/components/ui/Container.astro';
import Badge from '@/components/ui/Badge.astro';

const services = [
  { name: 'Strat Ai Web App', status: 'operational', uptime: '99.98%' },
  { name: 'Conviction Engine (API)', status: 'operational', uptime: '99.95%' },
  { name: 'Real-Time Data Pipeline', status: 'operational', uptime: '99.92%' },
  { name: 'WebSocket Streaming', status: 'operational', uptime: '99.90%' },
  { name: 'Options Chain Service', status: 'operational', uptime: '99.97%' },
  { name: 'Consensus & Analysis Engine', status: 'operational', uptime: '99.88%' },
  { name: 'Authentication & SSO', status: 'operational', uptime: '99.99%' },
];

const incidents = [
  { date: 'June 22, 2026', title: 'Elevated latency on Real-Time Data Feed', status: 'Resolved', desc: 'Real-time feeds experienced brief delay for ~15 minutes during NSE opening session due to upstream exchange delay. Auto-recovered.' },
  { date: 'June 14, 2026', title: 'Scheduled maintenance — Consensus Engine', status: 'Completed', desc: 'Planned 30-minute maintenance window for consensus system update. Zero downtime achieved.' },
];

const statusColors: Record<string, string> = {
  'operational': 'bg-success',
  'degraded': 'bg-warning',
  'outage': 'bg-error',
};
---
<PageLayout title="System Status" description="Real-time status of all Strat Ai services and infrastructure." badge="Status" badgeVariant="emerald" breadcrumbs={[{ label: 'Status' }]}>
  <!-- Overall -->
  <section class="py-16 md:py-20 bg-canvas transition-colors duration-300">
    <Container size="wide" class="!px-0">
      <div class="border-y border-hairline bg-surface-soft/5 p-8 md:p-12 text-center">
        <div class="flex items-center justify-center gap-3 mb-2">
          <span class="w-3 h-3 rounded-full bg-success animate-pulse"></span>
          <h2 class="type-display-sm text-ink">All Systems Operational</h2>
        </div>
        <p class="type-body-sm text-muted">Last updated: {new Date().toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</p>
      </div>
    </Container>
  </section>

  <!-- Services -->
  <section class="py-16 md:py-20 bg-canvas transition-colors duration-300">
    <Container size="wide" class="!px-0">
      <div class="border-y border-hairline divide-y divide-hairline bg-surface-soft/5">
        {services.map((svc) => (
          <div class="p-5 md:p-6 flex items-center justify-between hover:bg-surface-soft/10 transition-colors">
            <div class="flex items-center gap-3">
              <span class:list={['w-2.5 h-2.5 rounded-full shrink-0', statusColors[svc.status]]}></span>
              <span class="type-body-md text-ink font-medium">{svc.name}</span>
            </div>
            <div class="flex items-center gap-4">
              <span class="text-xs text-muted-soft font-mono">{svc.uptime}</span>
              <span class="text-xs text-success font-medium capitalize">{svc.status}</span>
            </div>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- Incidents -->
  <section class="py-16 md:py-20 bg-canvas transition-colors duration-300">
    <Container>
      <div class="max-w-[800px] mx-auto text-center mb-12">
        <Badge variant="orange" class="mb-4">Recent Incidents</Badge>
        <h2 class="type-display-lg leading-[1.1] tracking-tight text-ink">Incident history</h2>
      </div>
    </Container>
    <Container size="wide" class="!px-0">
      <div class="border-y border-hairline divide-y divide-hairline bg-surface-soft/5">
        {incidents.map((inc) => (
          <div class="p-6 md:p-8 flex flex-col gap-2">
            <div class="flex items-center gap-3">
              <span class="text-xs text-muted-soft">{inc.date}</span>
              <Badge variant={inc.status === 'Resolved' ? 'emerald' : 'default'}>{inc.status}</Badge>
            </div>
            <h3 class="type-title-sm text-ink">{inc.title}</h3>
            <p class="type-body-sm text-muted">{inc.desc}</p>
          </div>
        ))}
      </div>
    </Container>
  </section>
</PageLayout>
