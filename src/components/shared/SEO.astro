---
interface Props { title: string; description?: string; canonical?: string; ogImage?: string; ogType?: "website" | "article" | "product"; jsonLd?: Record<string, unknown> | Record<string, unknown>[]; noindex?: boolean; }
const { title, description = "Strat Ai — AI-powered trading intelligence for serious Indian F&O and Crypto traders. 5 ML agents, sub-50ms latency, zero-custody privacy.", canonical, ogImage = "/hero/hero-3d.png", ogType = "website", jsonLd, noindex = false } = Astro.props;
const siteUrl = Astro.site?.toString().replace(/\/$/, "") || "https://www.stratai.live";
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteUrl).toString();
const fullOgImage = ogImage.startsWith("http") ? ogImage : `${siteUrl}${ogImage}`;

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Strat Ai",
  url: siteUrl,
  description: "AI-powered trading intelligence platform for Indian financial markets.",
  foundingDate: "2026",
  knowsAbout: ["Artificial Intelligence", "Financial Markets", "Trading Intelligence", "Indian Stock Market", "Quantitative Research"],
};
const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: title,
  description,
  url: canonicalUrl,
  isPartOf: { "@type": "WebSite", name: "Strat Ai", url: siteUrl },
};
const allSchemas = [orgSchema, webPageSchema, ...(Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [])];
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />
{noindex && <meta name="robots" content="noindex, nofollow" />}
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:type" content={ogType} />
<meta property="og:image" content={fullOgImage} />
<meta property="og:site_name" content="Strat Ai" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullOgImage} />
{allSchemas.map((schema) => (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
))}
