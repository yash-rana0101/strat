---
/**
 * HowItWorks — Technology Stack section with terminal dashboard.
 * TRW BuiltFor pattern: 2-column bordered container + feature row + data row.
 */
import Container from '@/components/ui/Container.astro';
import Badge from '@/components/ui/Badge.astro';
import Icon from '@/components/ui/Icon.astro';
---

<section class="py-16 md:py-20 bg-canvas transition-colors duration-300" id="how-it-works" aria-labelledby="how-it-works-heading">
  <Container size="wide" class="!px-0">
    <div class="border-y border-hairline overflow-hidden bg-surface-soft/5">
      <!-- Top: 2-column layout -->
      <div class="grid grid-cols-1 lg:grid-cols-[0.85fr_1.15fr] divide-y lg:divide-y-0 lg:divide-x divide-hairline border-b border-hairline">
        <div class="flex flex-col items-start gap-6 p-8 md:p-12 lg:p-16 justify-center" data-reveal-group>
          <div data-reveal-item><Badge variant="emerald">The Anatomy of Intelligence</Badge></div>
          <h2 id="how-it-works-heading" class="type-display-lg leading-[1.1] tracking-tight text-ink" data-reveal-item>
            Methodology-driven precision trading
          </h2>
          <p class="type-body-md text-muted leading-relaxed" data-reveal-item>
            Strat Ai is built on a disciplined quantitative methodology. Access option chains, volatility matrices, and price action metrics in a unified, modern dashboard designed for risk management.
          </p>
        </div>

        <!-- Terminal Dashboard -->
        <div class="p-8 md:p-12 flex items-center justify-center bg-surface-soft/10 reveal reveal-scale-up">
          <div class="w-full bg-surface-soft border border-hairline rounded-2xl p-6 flex flex-col gap-5 relative overflow-hidden shadow-2xl">
            <div class="flex items-center justify-between pb-4 border-b border-hairline/60">
              <div class="flex items-center gap-2">
                <span class="w-3 h-3 rounded-full bg-red-500/80"></span>
                <span class="w-3 h-3 rounded-full bg-yellow-500/80"></span>
                <span class="w-3 h-3 rounded-full bg-green-500/80"></span>
                <span class="text-xs font-mono text-muted pl-2">STRAT_AI_TERMINAL_V1.0</span>
              </div>
              <Badge variant="emerald" class="text-[10px] uppercase font-semibold">Active Session</Badge>
            </div>

            <div id="tab-content-overview" class="grid grid-cols-1 md:grid-cols-2 gap-4 tab-content">
              <div class="bg-surface-card border border-hairline/50 p-4 rounded-xl flex flex-col gap-3">
                <div class="flex items-center justify-between">
                  <span class="text-xs font-semibold text-ink">CONVICTION SCORE</span>
                  <span class="text-[10px] text-badge-emerald font-bold">88% BULLISH</span>
                </div>
                <div class="flex flex-col gap-2">
                  <div class="flex items-center justify-between text-xs py-1 border-b border-hairline/30">
                    <span class="text-muted">Technical Analysis</span>
                    <span class="font-semibold text-success">+92%</span>
                  </div>
                  <div class="flex items-center justify-between text-xs py-1 border-b border-hairline/30">
                    <span class="text-muted">Market Sentiment</span>
                    <span class="font-semibold text-success">+78%</span>
                  </div>
                  <div class="flex items-center justify-between text-xs py-1">
                    <span class="text-muted">Predictive Trend</span>
                    <span class="font-semibold text-success">+85%</span>
                  </div>
                </div>
              </div>

              <div class="bg-surface-card border border-hairline/50 p-4 rounded-xl flex flex-col gap-3 justify-between">
                <span class="text-xs font-semibold text-ink">INDICATOR GRID</span>
                <div class="grid grid-cols-4 gap-2 text-center">
                  <div class="flex flex-col p-1.5 bg-canvas rounded border border-hairline/30">
                    <span class="text-[9px] text-muted-soft">RSI</span>
                    <span class="text-xs font-bold text-ink">62.4</span>
                  </div>
                  <div class="flex flex-col p-1.5 bg-canvas rounded border border-hairline/30">
                    <span class="text-[9px] text-muted-soft">VWAP</span>
                    <span class="text-xs font-bold text-ink">24.1K</span>
                  </div>
                  <div class="flex flex-col p-1.5 bg-canvas rounded border border-hairline/30">
                    <span class="text-[9px] text-muted-soft">MACD</span>
                    <span class="text-xs font-bold text-success">+1.2</span>
                  </div>
                  <div class="flex flex-col p-1.5 bg-canvas rounded border border-hairline/30">
                    <span class="text-[9px] text-muted-soft">OI Δ</span>
                    <span class="text-xs font-bold text-badge-emerald">+4.2%</span>
                  </div>
                </div>
              </div>
            </div>

            <!-- Analytics Tab Content -->
            <div id="tab-content-analytics" class="hidden grid grid-cols-1 md:grid-cols-2 gap-4 tab-content">
              <div class="bg-surface-card border border-hairline/50 p-4 rounded-xl flex flex-col gap-3">
                <div class="flex items-center justify-between">
                  <span class="text-xs font-semibold text-ink">VOLATILITY & REGIME</span>
                  <span class="text-[10px] text-badge-violet font-bold">IV PERCENTILE 74%</span>
                </div>
                <div class="flex flex-col gap-2">
                  <div class="flex items-center justify-between text-xs py-1 border-b border-hairline/30">
                    <span class="text-muted">Market Regime</span>
                    <span class="font-semibold text-success">Trending Bullish</span>
                  </div>
                  <div class="flex items-center justify-between text-xs py-1 border-b border-hairline/30">
                    <span class="text-muted">Hist. Volatility</span>
                    <span class="font-semibold text-ink">22.8%</span>
                  </div>
                  <div class="flex items-center justify-between text-xs py-1">
                    <span class="text-muted">ATR-scaled Move</span>
                    <span class="font-semibold text-ink">1.45%</span>
                  </div>
                </div>
              </div>

              <div class="bg-surface-card border border-hairline/50 p-4 rounded-xl flex flex-col gap-3 justify-between">
                <span class="text-xs font-semibold text-ink">ORDER FLOW METRICS</span>
                <div class="flex flex-col gap-2">
                  <div class="flex items-center justify-between text-xs py-1 border-b border-hairline/30">
                    <span class="text-muted">CVD Delta</span>
                    <span class="font-semibold text-success">+12.4M</span>
                  </div>
                  <div class="flex items-center justify-between text-xs py-1 border-b border-hairline/30">
                    <span class="text-muted">Vol Imbalance</span>
                    <span class="font-semibold text-success">Buy 58%</span>
                  </div>
                  <div class="flex items-center justify-between text-xs py-1">
                    <span class="text-muted">OFI Direction</span>
                    <span class="font-semibold text-success">Strong Buy</span>
                  </div>
                </div>
              </div>
            </div>

            <!-- Options Chain Tab Content -->
            <div id="tab-content-options" class="hidden grid grid-cols-1 md:grid-cols-2 gap-4 tab-content">
              <div class="bg-surface-card border border-hairline/50 p-4 rounded-xl flex flex-col gap-3">
                <div class="flex items-center justify-between">
                  <span class="text-xs font-semibold text-ink">OPTIONS METRICS</span>
                  <span class="text-[10px] text-badge-orange font-bold">PCR 1.18</span>
                </div>
                <div class="flex flex-col gap-2">
                  <div class="flex items-center justify-between text-xs py-1 border-b border-hairline/30">
                    <span class="text-muted">Max Pain Level</span>
                    <span class="font-semibold text-ink">24,150</span>
                  </div>
                  <div class="flex items-center justify-between text-xs py-1 border-b border-hairline/30">
                    <span class="text-muted">Total PE OI</span>
                    <span class="font-semibold text-success">14.2M</span>
                  </div>
                  <div class="flex items-center justify-between text-xs py-1">
                    <span class="text-muted">Total CE OI</span>
                    <span class="font-semibold text-ink">8.9M</span>
                  </div>
                </div>
              </div>

              <div class="bg-surface-card border border-hairline/50 p-4 rounded-xl flex flex-col gap-3 justify-between">
                <span class="text-xs font-semibold text-ink">CE / PE STRIKE CHAIN</span>
                <div class="flex flex-col gap-2.5">
                  <div class="flex items-center justify-between text-xs font-mono">
                    <span class="text-muted">PE: 4.8M</span>
                    <span class="font-bold text-ink px-1.5 py-0.5 bg-canvas rounded border border-hairline/40">24,100 Strike</span>
                    <span class="text-muted">CE: 2.1M</span>
                  </div>
                  <div class="flex items-center justify-between text-xs font-mono">
                    <span class="text-muted">PE: 2.4M</span>
                    <span class="font-bold text-ink px-1.5 py-0.5 bg-canvas rounded border border-hairline/40">24,150 Strike</span>
                    <span class="text-muted">CE: 5.6M</span>
                  </div>
                  <div class="flex items-center justify-between text-xs font-mono">
                    <span class="text-muted">PE: 1.2M</span>
                    <span class="font-bold text-ink px-1.5 py-0.5 bg-canvas rounded border border-hairline/40">24,200 Strike</span>
                    <span class="text-muted">CE: 8.9M</span>
                  </div>
                </div>
              </div>
            </div>

            <div class="flex items-center gap-1.5 bg-surface-card p-1 border border-hairline/60 rounded-full w-fit">
              <button data-tab="overview" class="tab-btn px-4 py-1.5 bg-primary text-on-primary rounded-full text-xs font-semibold shadow cursor-pointer transition-all duration-200">Overview</button>
              <button data-tab="analytics" class="tab-btn px-4 py-1.5 text-muted rounded-full text-xs font-semibold cursor-pointer transition-all duration-200">Analytics</button>
              <button data-tab="options" class="tab-btn px-4 py-1.5 text-muted rounded-full text-xs font-semibold cursor-pointer transition-all duration-200">Options Chain</button>
            </div>
          </div>
        </div>
      </div>

      <!-- Feature highlights row -->
      <div class="grid grid-cols-1 md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-hairline" data-reveal-group>
        <div class="reveal-item p-6 md:p-8 flex flex-col gap-2 hover:bg-surface-soft/10 transition-colors">
          <h4 class="type-title-sm text-ink font-semibold">Real-time data feeds</h4>
          <p class="text-xs text-muted">Continuous streaming of data allows for timely assessments of price action and options chains.</p>
        </div>
        <div class="reveal-item p-6 md:p-8 flex flex-col gap-2 hover:bg-surface-soft/10 transition-colors">
          <h4 class="type-title-sm text-ink font-semibold">Multiple Technical Indicators</h4>
          <p class="text-xs text-muted">RSI, VWAP, MACD, OI, and volatility skews processed in real-time for immediate insight.</p>
        </div>
        <div class="reveal-item p-6 md:p-8 flex flex-col gap-2 hover:bg-surface-soft/10 transition-colors">
          <h4 class="type-title-sm text-ink font-semibold">Consensus Decision Intelligence</h4>
          <p class="text-xs text-muted">Fuses technical indicators, market news sentiment, trend projection, and historical context into a single unified outlook.</p>
        </div>
      </div>
    </div>
  </Container>
</section>

<script>
  function initHowItWorksTabs() {
    const buttons = document.querySelectorAll('.tab-btn');
    const contents = document.querySelectorAll('.tab-content');

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const targetTab = btn.getAttribute('data-tab');

        // Update buttons styling
        buttons.forEach(b => {
          b.classList.remove('bg-primary', 'text-on-primary', 'shadow');
          b.classList.add('text-muted');
        });
        btn.classList.add('bg-primary', 'text-on-primary', 'shadow');
        btn.classList.remove('text-muted');

        // Update content visibility
        contents.forEach(content => {
          if (content.id === `tab-content-${targetTab}`) {
            content.classList.remove('hidden');
          } else {
            content.classList.add('hidden');
          }
        });
      });
    });
  }

  initHowItWorksTabs();
  document.addEventListener('astro:after-swap', initHowItWorksTabs);
</script>
