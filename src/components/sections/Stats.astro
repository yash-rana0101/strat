---
import Container from '@/components/ui/Container.astro';
import Badge from '@/components/ui/Badge.astro';
---

<section class="py-16 md:py-20 bg-canvas transition-colors duration-300" id="stats" aria-labelledby="stats-heading">
  <Container>
    <div class="max-w-[800px] mx-auto text-center mb-12" data-reveal-group>
      <div data-reveal-item><Badge variant="emerald" class="mb-4">By The Numbers</Badge></div>
      <h2 id="stats-heading" class="type-display-lg leading-[1.1] tracking-tight text-ink" data-reveal-item>
        Performance that speaks
      </h2>
    </div>
  </Container>

  <Container size="wide" class="!px-0">
    <div class="border-y border-hairline overflow-hidden bg-surface-soft/5">
      <div class="grid grid-cols-2 md:grid-cols-4 divide-y md:divide-y-0 md:divide-x divide-hairline" data-reveal-group>
        <div class="reveal-item p-8 md:p-10 text-center flex flex-col gap-2">
          <span class="text-4xl md:text-5xl font-bold text-ink font-display tracking-tight" data-count="5">5</span>
          <span class="type-title-sm text-ink">Data Dimensions</span>
          <span class="text-xs text-muted">Fused into one score</span>
        </div>
        <div class="reveal-item p-8 md:p-10 text-center flex flex-col gap-2">
          <span class="text-4xl md:text-5xl font-bold text-ink font-display tracking-tight" data-count="16">16+</span>
          <span class="type-title-sm text-ink">Technical Metrics</span>
          <span class="text-xs text-muted">Calculated in real-time</span>
        </div>
        <div class="reveal-item p-8 md:p-10 text-center flex flex-col gap-2">
          <span class="text-4xl md:text-5xl font-bold text-ink font-display tracking-tight">Real-Time</span>
          <span class="type-title-sm text-ink">Data Streaming</span>
          <span class="text-xs text-muted">Instant terminal feed</span>
        </div>
        <div class="reveal-item p-8 md:p-10 text-center flex flex-col gap-2">
          <span class="text-4xl md:text-5xl font-bold text-ink font-display tracking-tight" data-count="150">150+</span>
          <span class="type-title-sm text-ink">Professional Users</span>
          <span class="text-xs text-muted">Testing in Indian F&O</span>
        </div>
      </div>

      <!-- Testimonial -->
      <div class="border-t border-hairline p-8 md:p-12" data-reveal-group>
        <div class="max-w-[800px] mx-auto">
          <div class="flex items-center gap-2 mb-4" data-reveal-item>
            <span class="w-1.5 h-1.5 rounded-full bg-badge-emerald"></span>
            <span class="text-[10px] font-mono font-bold tracking-widest uppercase text-badge-emerald">User Feedback</span>
          </div>
          <blockquote class="type-display-sm text-ink leading-relaxed mb-6" data-reveal-item>
            "Strat Ai's unified consensus dashboard replaced six browser tabs and gave me conviction I never had trading alone. The trend projection overlay is incredibly helpful on 10-minute timeframes."
          </blockquote>
          <div class="flex items-center gap-3" data-reveal-item>
            <div class="w-10 h-10 rounded-full bg-badge-emerald/20 text-badge-emerald flex items-center justify-center font-bold font-mono text-sm">AR</div>
            <div>
              <span class="block text-sm font-semibold text-ink">Aditya R.</span>
              <span class="block text-xs text-muted">F&O Swing Trader · Beta Tester</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </Container>
</section>
