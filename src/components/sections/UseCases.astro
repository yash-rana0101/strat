---
import Container from '@/components/ui/Container.astro';
import Badge from '@/components/ui/Badge.astro';
import FeatureCard from '@/components/ui/FeatureCard.astro';
---

<section class="py-16 md:py-20 bg-canvas transition-colors duration-300" id="use-cases" aria-labelledby="use-cases-heading">
  <Container>
    <div class="max-w-[800px] mx-auto text-center mb-12 md:mb-16" data-reveal-group>
      <div data-reveal-item><Badge variant="emerald" class="mb-4">Key Capabilities</Badge></div>
      <h2 id="use-cases-heading" class="type-display-lg leading-[1.1] tracking-tight text-ink" data-reveal-item>
        Key capabilities for Strat Ai in F&O trading
      </h2>
      <p class="type-body-md text-muted mt-4" data-reveal-item>
        Every panel is designed to provide clear, actionable market insights and support disciplined execution.
      </p>
    </div>
  </Container>

  <Container>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6" data-reveal-group>
      <div class="reveal-item flex flex-col h-full">
        <FeatureCard
          icon="chart"
          title="Options Chain Analytics"
          description="Decodes F&O activity. Analyzes Open Interest patterns, volume profiles, and strike dynamics to map key market zones and alert you to potential breakouts."
        />
      </div>
      <div class="reveal-item flex flex-col h-full">
        <FeatureCard
          icon="shield-check"
          title="Risk-to-Reward Auditor"
          description="Performs a complete audit of support/resistance zones, trend strength, and risk parameters to check your setups before you deploy capital."
        />
      </div>
      <div class="reveal-item flex flex-col h-full">
        <FeatureCard
          icon="layers"
          title="Market Anomaly Alerts"
          description="Monitors market movements for unusual volume surges, rapid sector shifts, or price departures, translating them into clear contextual narratives."
        />
      </div>
    </div>
  </Container>
</section>
