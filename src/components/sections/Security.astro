---
/**
 * Security — TRW WhyTRW pattern: globe visual left + security features right.
 */
import Container from '@/components/ui/Container.astro';
import Badge from '@/components/ui/Badge.astro';
import Icon from '@/components/ui/Icon.astro';
---

<section class="py-16 md:py-20 bg-canvas transition-colors duration-300" id="security" aria-labelledby="security-heading">
  <Container size="wide" class="!px-0">
    <div class="grid grid-cols-1 lg:grid-cols-2 border-y border-hairline overflow-hidden divide-y lg:divide-y-0 lg:divide-x divide-hairline bg-surface-soft/5">
      <!-- Left: Abstract Shield SVG -->
      <div class="p-8 md:p-12 lg:p-16 flex items-center justify-center relative select-none overflow-hidden min-h-[450px] md:min-h-[420px] group/shield reveal reveal-scale-up">
        <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
          <div class="absolute w-[350px] h-[350px] bg-brand-accent/10 opacity-60 group-hover/shield:opacity-90 blur-[100px] rounded-full transition-opacity duration-1000"></div>
          <!-- Shield SVG -->
          <svg viewBox="0 0 200 240" width="220" height="260" class="relative z-10 drop-shadow-[0_20px_50px_rgba(16,185,129,0.15)]">
            <defs>
              <linearGradient id="shieldGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#10b981" stop-opacity="0.3"/>
                <stop offset="100%" stop-color="#06b6d4" stop-opacity="0.1"/>
              </linearGradient>
            </defs>
            <path d="M100 10 L180 50 L180 130 C180 180 140 220 100 235 C60 220 20 180 20 130 L20 50 Z" fill="url(#shieldGrad)" stroke="#10b981" stroke-width="1.5" stroke-opacity="0.5"/>
            <path d="M100 30 L160 60 L160 125 C160 165 130 195 100 210 C70 195 40 165 40 125 L40 60 Z" fill="none" stroke="#10b981" stroke-width="0.5" stroke-opacity="0.3"/>
            <!-- Checkmark -->
            <polyline points="72 120 92 140 130 100" fill="none" stroke="#10b981" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" opacity="0.8"/>
            <!-- Orbiting dots -->
            <circle cx="100" cy="10" r="3" fill="#10b981" opacity="0.6"/>
            <circle cx="180" cy="90" r="2.5" fill="#06b6d4" opacity="0.5"/>
            <circle cx="20" cy="90" r="2.5" fill="#34d399" opacity="0.5"/>
          </svg>
        </div>
      </div>

      <!-- Right: Security Features -->
      <div class="flex flex-col items-start gap-6 p-8 md:p-12 lg:p-16 justify-center" data-reveal-group>
        <div data-reveal-item><Badge variant="emerald">Security & Trust</Badge></div>
        <h2 id="security-heading" class="type-display-lg leading-[1.1] tracking-tight text-ink" data-reveal-item>
          Zero-custody terminal. Your capital, your control.
        </h2>

        <div class="flex flex-wrap gap-2" data-reveal-item>
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-surface-card border border-hairline/60 rounded-full text-xs text-muted">
            <Icon name="shield-check" size={12} class="text-badge-emerald" /> Zero Custody
          </span>
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-surface-card border border-hairline/60 rounded-full text-xs text-muted">
            <Icon name="zap" size={12} class="text-badge-violet" /> TLS 1.3 Encrypted
          </span>
        </div>

        <ul class="list-none flex flex-col gap-5 mt-1" role="list">
          <li class="flex gap-4" data-reveal-item>
            <div class="w-5 h-5 rounded-full bg-badge-emerald/20 text-badge-emerald flex items-center justify-center shrink-0 mt-1">
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12" /></svg>
            </div>
            <div>
              <h4 class="type-title-sm text-ink font-semibold">No broker API keys required</h4>
              <p class="type-body-sm text-muted">Strat Ai never touches your brokerage account. We provide intelligence — you execute through your own broker.</p>
            </div>
          </li>
          <li class="flex gap-4" data-reveal-item>
            <div class="w-5 h-5 rounded-full bg-badge-emerald/20 text-badge-emerald flex items-center justify-center shrink-0 mt-1">
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12" /></svg>
            </div>
            <div>
              <h4 class="type-title-sm text-ink font-semibold">End-to-end encryption</h4>
              <p class="type-body-sm text-muted">All data in transit is encrypted with TLS 1.3. Query logs are ephemeral and never stored beyond session.</p>
            </div>
          </li>
          <li class="flex gap-4" data-reveal-item>
            <div class="w-5 h-5 rounded-full bg-badge-emerald/20 text-badge-emerald flex items-center justify-center shrink-0 mt-1">
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12" /></svg>
            </div>
            <div>
              <h4 class="type-title-sm text-ink font-semibold">99.9% uptime SLA</h4>
              <p class="type-body-sm text-muted">Redundant infrastructure across availability zones ensures market-hours reliability.</p>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </Container>
</section>
