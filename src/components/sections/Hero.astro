---
/**
 * Hero — Split 2-column layout with isometric 3D SVG graphic.
 * Emerald/green gradient replaces TRW's orange/pink/violet.
 */
import Container from '@/components/ui/Container.astro';
import Button from '@/components/ui/Button.astro';
import Badge from '@/components/ui/Badge.astro';

const gridSize = 5;
const cubeSize = 30;
const cx = 220;
const cy = 180;
const heights = [
  [4, 4, 3, 2, 1],
  [4, 3, 2, 1, 1],
  [3, 2, 2, 1, 0],
  [2, 1, 1, 0, 0],
  [1, 1, 0, 0, 0]
];

function getBaseColor(gx: number, gy: number) {
  const total = (gridSize - 1) * 2;
  const t = (gx + gy) / total;
  // Emerald (#10b981) -> Teal (#14b8a6) -> Cyan (#06b6d4)
  const emerald = [16, 185, 129];
  const teal = [20, 184, 166];
  const cyan = [6, 182, 212];
  let r, g, b;
  if (t < 0.5) {
    const localT = t * 2;
    r = Math.round(emerald[0] * (1 - localT) + teal[0] * localT);
    g = Math.round(emerald[1] * (1 - localT) + teal[1] * localT);
    b = Math.round(emerald[2] * (1 - localT) + teal[2] * localT);
  } else {
    const localT = (t - 0.5) * 2;
    r = Math.round(teal[0] * (1 - localT) + cyan[0] * localT);
    g = Math.round(teal[1] * (1 - localT) + cyan[1] * localT);
    b = Math.round(teal[2] * (1 - localT) + cyan[2] * localT);
  }
  return `rgb(${r}, ${g}, ${b})`;
}
---

<section class="relative pt-24 lg:pt-32 overflow-hidden bg-canvas transition-colors duration-300" id="hero" aria-labelledby="hero-heading">
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute inset-0 opacity-[0.03] dark:opacity-[0.15] [mask-image:radial-gradient(ellipse_60%_60%_at_50%_40%,black_20%,transparent_80%)]" style="background-image: linear-gradient(var(--color-hairline) 1px, transparent 1px), linear-gradient(90deg, var(--color-hairline) 1px, transparent 1px); background-size: 48px 48px;"></div>
    <div class="absolute top-[10%] right-[5%] w-[500px] h-[500px] bg-[radial-gradient(ellipse_at_center,rgba(16,185,129,0.06)_0%,transparent_70%)] blur-[80px]"></div>
    <div class="absolute bottom-[10%] left-[5%] w-[400px] h-[400px] bg-[radial-gradient(ellipse_at_center,rgba(6,182,212,0.04)_0%,transparent_70%)] blur-[80px]"></div>
  </div>

  <Container size="wide" class="!px-0">
    <div class="grid grid-cols-1 lg:grid-cols-2 border-y border-hairline divide-y lg:divide-y-0 lg:divide-x divide-hairline bg-surface-soft/5 relative z-10">
      <div class="flex flex-col items-start text-left gap-5 p-8 md:p-10 lg:p-10 justify-center" data-reveal-group>
        <div data-reveal-item>
          <Badge variant="emerald" class="px-3.5 py-1">Built by Trading & Research Wing</Badge>
        </div>

        <h1 id="hero-heading" class="type-display-xl tracking-tight leading-[1.08] text-ink text-left" data-reveal-item>
          Trade with quantitative<br />conviction
        </h1>

        <p class="type-body-md text-muted text-base md:text-lg leading-relaxed" data-reveal-item>
          A proprietary trading terminal purpose-built for Indian markets by the <a href="https://tradingrw.com" class="text-emerald hover:underline" target="_blank" rel="noopener noreferrer">Trading and Research Wing</a>. Fuse live indicators, volatility matrices, option chain analytics, and news sentiment into a single conviction dashboard.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 mt-2 w-full sm:w-auto" data-reveal-item>
          <Button variant="primary" size="lg" href="/#pricing" class="!rounded-full px-8 py-3.5 hover:scale-[1.02] transition-transform">
            Get Access
          </Button>
          <Button variant="secondary" size="lg" href="#how-it-works" class="!rounded-full px-8 py-3.5">
            Learn More
          </Button>
        </div>
      </div>

      <div class="w-full aspect-[5/4] lg:aspect-auto min-h-[300px] lg:min-h-[400px] p-6 lg:p-8 flex items-center justify-center relative bg-surface-soft/10 reveal reveal-scale-up">
        <svg viewBox="0 0 440 420" width="100%" height="100%" class="drop-shadow-[0_20px_50px_rgba(16,185,129,0.12)] select-none overflow-visible max-w-[380px] lg:max-w-none">
          {Array.from({ length: gridSize }).map((_, gx) =>
            Array.from({ length: gridSize }).map((_, gy) => {
              const maxZ = heights[gx][gy];
              return Array.from({ length: maxZ }).map((_, gz) => {
                const sx = cx + (gx - gy) * cubeSize * 0.866;
                const sy = cy + (gx + gy) * cubeSize * 0.5 - gz * cubeSize;
                const color = getBaseColor(gx, gy);
                const topPoints = `${sx},${sy - cubeSize} ${sx + cubeSize * 0.866},${sy - cubeSize * 0.5} ${sx},${sy} ${sx - cubeSize * 0.866},${sy - cubeSize * 0.5}`;
                const leftPoints = `${sx - cubeSize * 0.866},${sy - cubeSize * 0.5} ${sx},${sy} ${sx},${sy + cubeSize} ${sx - cubeSize * 0.866},${sy + cubeSize * 0.5}`;
                const rightPoints = `${sx},${sy} ${sx + cubeSize * 0.866},${sy - cubeSize * 0.5} ${sx + cubeSize * 0.866},${sy + cubeSize * 0.5} ${sx},${sy + cubeSize}`;
                return (
                  <g class="transition-all duration-500 hover:-translate-y-2 cursor-pointer">
                    <polygon points={topPoints} fill={color} />
                    <polygon points={leftPoints} fill={color} />
                    <polygon points={leftPoints} fill="#000000" fill-opacity="0.25" />
                    <polygon points={rightPoints} fill={color} />
                    <polygon points={rightPoints} fill="#000000" fill-opacity="0.1" />
                    <polygon points={topPoints} fill="none" stroke="#ffffff" stroke-opacity="0.1" stroke-width="0.5" />
                    <polygon points={leftPoints} fill="none" stroke="#ffffff" stroke-opacity="0.1" stroke-width="0.5" />
                    <polygon points={rightPoints} fill="none" stroke="#ffffff" stroke-opacity="0.1" stroke-width="0.5" />
                  </g>
                );
              });
            })
          )}
        </svg>
      </div>
    </div>
  </Container>
</section>
