---
import Container from '@/components/ui/Container.astro';
import Button from '@/components/ui/Button.astro';
import Badge from '@/components/ui/Badge.astro';
---

<section class="py-16 md:py-24 bg-canvas transition-colors duration-300" id="cta" aria-labelledby="cta-heading">
  <Container>
    <div class="relative text-center flex flex-col items-center gap-6 max-w-[650px] mx-auto" data-reveal-group>
      <div data-reveal-item><Badge variant="emerald">Get Started</Badge></div>
      <h2 id="cta-heading" class="type-display-md text-ink leading-tight font-bold" data-reveal-item>
        Trading intelligence, revolutionized
      </h2>
      <p class="type-body-md text-muted max-w-[500px]" data-reveal-item>
        Join professional traders already using Strat Ai to trade with conviction. Start free — upgrade when you need institutional-grade power.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 mt-2 w-full sm:w-auto" data-reveal-item>
        <Button variant="primary" size="lg" href="/download" class="!rounded-full px-8 py-3.5 hover:scale-[1.02] transition-transform">
          Start Trading 
        </Button>
        <Button variant="secondary" size="lg" href="#features" class="!rounded-full px-8 py-3.5">
          Explore Features
        </Button>
      </div>
    </div>
  </Container>
</section>
