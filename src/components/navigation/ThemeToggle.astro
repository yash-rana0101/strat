---
import Icon from '@/components/ui/Icon.astro';
interface Props { class?: string; }
const { class: className } = Astro.props;
---
<button
  class:list={['theme-toggle relative flex items-center justify-center border border-hairline rounded-full bg-transparent text-ink cursor-pointer w-9 h-9 shrink-0 overflow-hidden', className]}
  aria-label="Toggle dark/light mode"
  type="button"
>
  <span class="absolute inset-0 flex items-center justify-center transition-all duration-500 ease-[cubic-bezier(0.4,0,0.2,1)] [[data-theme=light]_&]:opacity-0 [[data-theme=light]_&]:rotate-45">
    <Icon name="sun" size={18} />
  </span>
  <span class="absolute inset-0 flex items-center justify-center transition-all duration-500 ease-[cubic-bezier(0.4,0,0.2,1)] opacity-0 -rotate-45 [[data-theme=light]_&]:opacity-100 [[data-theme=light]_&]:rotate-0">
    <Icon name="moon" size={18} />
  </span>
</button>

<script>
  function initTheme() {
    const toggles = document.querySelectorAll('.theme-toggle');
    if (toggles.length === 0) return;
    const getTheme = (): string => localStorage.getItem('strat-theme') || 'dark';
    const setTheme = (theme: string): void => {
      document.documentElement.setAttribute('data-theme', theme);
      localStorage.setItem('strat-theme', theme);
    };
    setTheme(getTheme());
    toggles.forEach((toggle) => {
      toggle.addEventListener('click', () => {
        const current = getTheme();
        setTheme(current === 'dark' ? 'light' : 'dark');
      });
    });
  }
  initTheme();
  document.addEventListener('astro:after-swap', initTheme);
</script>
