---
interface Props { label?: string; class?: string; }
const { label, class: className } = Astro.props;
---
<div class:list={['flex items-center gap-4 w-full', className]} role="separator">
  {label ? (
    <>
      <span class="flex-1 h-[1px] bg-hairline" />
      <span class="text-muted-soft type-caption whitespace-nowrap">{label}</span>
      <span class="flex-1 h-[1px] bg-hairline" />
    </>
  ) : (
    <span class="flex-1 h-[1px] bg-hairline" />
  )}
</div>
