---
/**
 * Prose — Typography wrapper for long-form content.
 * Applies consistent heading hierarchy, paragraph spacing, list styling,
 * code blocks, blockquotes, and tables using TRW design tokens.
 */

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class:list={['prose-trw', className]}>
  <slot />
</div>

<style is:global>
  .prose-trw {
    color: var(--color-body);
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.75;
    max-width: 72ch;
  }

  /* Headings */
  .prose-trw h1 {
    font-family: var(--font-display);
    font-size: 36px;
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -1px;
    color: var(--color-ink);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .prose-trw h2 {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.5px;
    color: var(--color-ink);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-hairline);
  }

  .prose-trw h3 {
    font-family: var(--font-body);
    font-size: 22px;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.3px;
    color: var(--color-ink);
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }

  .prose-trw h4 {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 600;
    line-height: 1.4;
    color: var(--color-ink);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  /* First heading shouldn't have top margin */
  .prose-trw > h1:first-child,
  .prose-trw > h2:first-child,
  .prose-trw > h3:first-child {
    margin-top: 0;
  }

  /* Paragraphs */
  .prose-trw p {
    margin-bottom: 1.25rem;
  }

  /* Links */
  .prose-trw a {
    color: var(--color-ink);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--color-muted-soft);
    transition: text-decoration-color 0.2s ease;
  }

  .prose-trw a:hover {
    text-decoration-color: var(--color-ink);
  }

  /* Lists */
  .prose-trw ul,
  .prose-trw ol {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .prose-trw ul {
    list-style-type: disc;
  }

  .prose-trw ol {
    list-style-type: decimal;
  }

  .prose-trw li {
    margin-bottom: 0.375rem;
  }

  .prose-trw li::marker {
    color: var(--color-muted-soft);
  }

  /* Blockquotes */
  .prose-trw blockquote {
    border-left: 3px solid var(--color-hairline);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    color: var(--color-muted);
    font-style: italic;
  }

  /* Code - inline */
  .prose-trw code {
    font-family: var(--font-code);
    font-size: 14px;
    background-color: var(--color-surface-soft);
    border: 1px solid var(--color-hairline);
    border-radius: 4px;
    padding: 2px 6px;
    color: var(--color-ink);
  }

  /* Code - blocks */
  .prose-trw pre {
    background-color: var(--color-surface-soft);
    border: 1px solid var(--color-hairline);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
    overflow-x: auto;
  }

  .prose-trw pre code {
    background: none;
    border: none;
    padding: 0;
    font-size: 14px;
    line-height: 1.6;
  }

  /* Tables */
  .prose-trw table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 14px;
  }

  .prose-trw th {
    text-align: left;
    font-weight: 600;
    color: var(--color-ink);
    padding: 0.75rem 1rem;
    border-bottom: 2px solid var(--color-hairline);
  }

  .prose-trw td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--color-hairline-soft);
  }

  .prose-trw tr:last-child td {
    border-bottom: none;
  }

  /* Horizontal rule */
  .prose-trw hr {
    border: none;
    border-top: 1px solid var(--color-hairline);
    margin: 2.5rem 0;
  }

  /* Strong & emphasis */
  .prose-trw strong {
    font-weight: 600;
    color: var(--color-ink);
  }

  .prose-trw em {
    font-style: italic;
  }

  /* Images */
  .prose-trw img {
    border-radius: 8px;
    border: 1px solid var(--color-hairline);
    margin: 1.5rem 0;
    max-width: 100%;
    height: auto;
  }
</style>
